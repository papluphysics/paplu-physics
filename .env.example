# ============================================================
#  PAPLU PHYSICS — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase (get from supabase.com > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Google OAuth (get from console.cloud.google.com) ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# --- Razorpay (get from dashboard.razorpay.com) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# --- Cloudflare R2 (get from dash.cloudflare.com > R2) ---
R2_ACCOUNT_ID=6fbeb9a7d8cc84d1a395bf73ac501177
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET_NAME=paplu-physics-pdfs
R2_PUBLIC_URL=https://YOUR_R2_DOMAIN

# --- App Config ---
NEXT_PUBLIC_SITE_URL=https://papluphysics.in
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
ADMIN_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_STRING

# --- Razorpay Webhook ---
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
